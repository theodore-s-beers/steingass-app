{
	"name": "steingass-app",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsgo --tsconfig ./tsconfig.json",
		"check:watch": "wrangler types --check && svelte-kit sync && svelte-check --tsgo --tsconfig ./tsconfig.json --watch",
		"dev": "vite dev",
		"format": "oxfmt .",
		"lint": "oxfmt --check . && oxlint .",
		"prepare": "svelte-kit sync || echo ''",
		"preview": "vite preview",
		"types": "wrangler types"
	},
	"dependencies": {
		"marked": "^18.0.6"
	},
	"devDependencies": {
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.3",
		"@types/node": "^26.1.1",
		"@typescript/native": "npm:typescript@^7.0.2",
		"oxfmt": "^0.59.0",
		"oxlint": "^1.74.0",
		"svelte": "^5.56.7",
		"svelte-check": "^4.7.3",
		"tailwindcss": "^4.3.3",
		"typescript": "^6.0.3",
		"vite": "^8.1.5",
		"wrangler": "^4.112.0"
	}
}
